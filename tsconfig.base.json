{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@cup-and-co/design-tokens": ["./packages/design-tokens/src/index.ts"],
      "@cup-and-co/types": ["./packages/types/src/index.ts"],
      "@cup-and-co/i18n": ["./packages/i18n/src/index.ts"]
    }
  }
}
