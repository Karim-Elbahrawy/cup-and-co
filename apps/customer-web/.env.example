NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry (Phase 1.1 of UPGRADE-PLAN.md). Leave NEXT_PUBLIC_SENTRY_DSN blank
# in dev — the SDK becomes a no-op. In production, paste the DSN from
# sentry.io → cup-co-web project settings.
NEXT_PUBLIC_SENTRY_DSN=
# Optional: tune sample rate (0.0–1.0). Default 0.1.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Server-side DSN (defaults to NEXT_PUBLIC_SENTRY_DSN if unset). Set this
# separately if you want server errors to go to a different Sentry project.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Required only in CI for source-map upload. Leave blank locally.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog client-side analytics (Phase 1.2 of UPGRADE-PLAN.md). Leave blank
# in dev — SDK becomes a no-op. In production paste the project key from
# eu.posthog.com (or your chosen region).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
