# Cup & Co Kiosk — local dev env
# Copy this file to .env.local in apps/kiosk and run:
#   pnpm -F @cup-and-co/kiosk dev      (port 3002)
# alongside:
#   pnpm -F @cup-and-co/api dev        (port 4000)
#
# In production these come from Vercel project settings — see
# docs/runbooks/go-live-kiosk.md for the deploy guide.

# Where the kiosk POSTs orders. Locally this is the API on 4000.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Shared bearer token across the entire kiosk fleet. Must match
# KIOSK_BEARER_TOKEN in apps/api/.env exactly. The kiosk adds this to
# every request via the Authorization header so the API can resolve a
# synthetic kiosk:<id> user without per-customer JWTs.
NEXT_PUBLIC_KIOSK_BEARER=local-kiosk-bearer

# Per-device kiosk identity. Generate one uuid per physical iPad and
# keep a record (we'll surface this in the admin's K6 multi-kiosk view).
# The default below is fine for local development.
NEXT_PUBLIC_KIOSK_ID=00000000-0000-0000-0000-000000000001
