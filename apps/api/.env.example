# Loyalty
LOYALTY_ONLINE_MULTIPLIER=1.0
LOYALTY_CASH_MULTIPLIER=0.5
LOYALTY_QR_MULTIPLIER=0.25
LOYALTY_POINTS_PER_DISCOUNT_BLOCK=100
LOYALTY_DISCOUNT_EGP_PER_BLOCK=5

# Game
