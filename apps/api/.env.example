# JWT
JWT_SECRET=replace-with-random-secret-min-32-chars

# Paymob (Egypt)
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=local-dev-secret
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_WALLET=
